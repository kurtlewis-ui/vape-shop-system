# Application
NODE_ENV=development
PORT=4000
API_PREFIX=api/v1

# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/vape_shop_db?schema=public"

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-32-chars
JWT_EXPIRATION=15m
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production-min-32
JWT_REFRESH_EXPIRATION=7d

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# CORS
CORS_ORIGIN=http://localhost:3000

# Rate Limiting
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100

# Bcrypt
BCRYPT_ROUNDS=12

# Session
SESSION_TIMEOUT=900
SESSION_ABSOLUTE_TIMEOUT=28800

# Email (SendGrid) - Optional
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@vapeshop.com

# AWS S3 (for backups) - Optional
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=vape-shop-backups
AWS_REGION=us-east-1

# Monitoring - Optional
SENTRY_DSN=
